# ── Backend (prefix: QF_) ───────────────────────────────
# Database URL (SQLite default)
QF_DATABASE_URL=sqlite+aiosqlite:///./questionnaire_filler.db

# Similarity threshold for semantic matching (0.0 - 1.0)
QF_SIMILARITY_THRESHOLD=0.75

# Sentence-transformer model name
QF_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Allowed CORS origins (JSON array)
QF_CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend ─────────────────────────────────────────────
# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
