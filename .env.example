# ── Backend (prefix: QF_) ───────────────────────────────
# Database URL (SQLite default)
QF_DATABASE_URL=sqlite+aiosqlite:///./questionnaire_filler.db

# Similarity threshold for semantic matching (0.0 - 1.0)
QF_SIMILARITY_THRESHOLD=0.75

# Sentence-transformer model name
QF_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Allowed CORS origins (JSON array)
QF_CORS_ORIGINS=["http://localhost:3000"]

# ── Optional Agent (OpenAI-compatible) ────────────────────────────
# Master switch for AI agent mode features
QF_AGENT_ENABLED=false

# Backend default provider settings (supported: openai, anthropic)
QF_AGENT_PROVIDER=openai
QF_AGENT_API_BASE=https://api.openai.com/v1
QF_AGENT_API_KEY=
QF_AGENT_MODEL=gpt-4.1-nano
QF_AGENT_DEFAULT_MODE=agent

# Optional agent tuning
QF_AGENT_TIMEOUT_SECONDS=45
QF_AGENT_MAX_QUESTIONS_PER_CALL=20
QF_AGENT_MAX_CONTEXT_CHARS=6000

# ── Frontend ─────────────────────────────────────────────
# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
